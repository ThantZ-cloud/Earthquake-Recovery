{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "app/dist",
  "installCommand": "npm run install:all",
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
